# Ticketmaster Discovery API
# Получить бесплатно: https://developer.ticketmaster.com/
TICKETMASTER_API_KEY=your_api_key_here

# Supabase — значения из Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# Публичный адрес сайта (для ссылок в письмах). На проде — твой домен.
NEXT_PUBLIC_SITE_URL=https://ravepass-two.vercel.app

# Resend (отправка писем) — https://resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxx
# Отправитель. Для прода нужен верифицированный домен в Resend.
RESEND_FROM=RavePass <noreply@your-domain.com>

# Секрет для защиты cron-эндпоинта (любая длинная случайная строка)
CRON_SECRET=your-long-random-secret
